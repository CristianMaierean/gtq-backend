# Anthropic (Claude) API
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/technews

# Shopify Admin API — same store as the PC Parts scripts
SHOPIFY_STORE=gamertech-toronto
SHOPIFY_ADMIN_TOKEN=shpca_...
SHOPIFY_API_VERSION=2024-10

# Blog to publish to (created automatically on first run if it doesn't exist)
SHOPIFY_NEWS_BLOG_TITLE=PC Tech News
SHOPIFY_NEWS_BLOG_HANDLE=pc-tech-news

# How many days back to look for "new" RSS items each run
LOOKBACK_DAYS=2
